@using Syncfusion.Blazor.RichTextEditor

<SfRichTextEditor>
    <RichTextEditorToolbarSettings Items = "@Tools" />
    <p>The Rich Text Editor provides checklist support to help you create task-based content.
    You can add checklist items and update their status as you progress.</p>
    <p><b>Key features:</b></p>
    <ul class="e-rte-checklist">
        <li><p>Add checklist items directly within the editor</p></li>
        <li class="e-rte-checklist-checked"><p>Select or deselect items to mark progress</p></li>
        <li><p>Use checklists for tasks, notes, or step-by-step workflows</p></li>
    </ul>
</SfRichTextEditor>
@code {
    private List<ToolbarItemModel> Tools = new List<ToolbarItemModel>()
    {
        new ToolbarItemModel() { Command = ToolbarCommand.Checklist }
    };
}