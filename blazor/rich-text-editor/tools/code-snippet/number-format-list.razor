@using Syncfusion.Blazor.RichTextEditor

<SfRichTextEditor>
    <RichTextEditorToolbarSettings Items = "@Tools" />
    <RichTextEditorNumberFormatList Items="@NumberList" />
    <p>The Numbered List feature in the Rich Text Editor allows users to create ordered lists, where each item is displayed with a sequence number. This is useful for organizing steps, instructions, or ranked information.</p>
    <p><b>Key features:</b></p>
    <ol>
        <li><p>Supports different numbering formats such as numeric, alphabetic, and Roman styles.</p></li>
        <li><p>Allows creation of nested (multi-level) lists.</p></li>
        <li><p>Automatically updates numbering when items are edited.</p></li>
        <li><p>Provides easy controls through the toolbar for list management.</p></li>
    </ol>
</SfRichTextEditor>
@code {
    private List<ToolbarItemModel> Tools = new List<ToolbarItemModel>()
    {
        new ToolbarItemModel() { Command = ToolbarCommand.NumberFormatList }
    };
    List<DropDownItemModel> NumberList = new List<DropDownItemModel>() {
        new DropDownItemModel() { Text = "None", Value = "none" },
        new DropDownItemModel() { Text = "Number", Value = "decimal" },
        new DropDownItemModel() { Text = "Upper Alpha", Value = "upper-alpha" },
        new DropDownItemModel() { Text = "Lower Alpha", Value = "lower-alpha" }
    };
}