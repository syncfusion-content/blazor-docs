@using Syncfusion.Blazor.RichTextEditor

<SfRichTextEditor>
    <RichTextEditorToolbarSettings Items = "@Tools" />
    <p>The Rich Text Editor provides indent and outdent options to adjust the spacing of your content. These options help organize text visually and improve readability.</p>
    <p><b>Key features:</b></p>
    <ul>
        <li>
            Increase indentation to create visual hierarchy
            <ul>
                <li>Decrease indentation to realign content</li>
            </ul>
        </li>
        <li>Quickly format paragraphs and lists for better structure</li>
    </ul>
</SfRichTextEditor>
@code {
    private List<ToolbarItemModel> Tools = new List<ToolbarItemModel>()
    {
        new ToolbarItemModel() { Command = ToolbarCommand.Indent },
        new ToolbarItemModel() { Command = ToolbarCommand.Outdent }
    };
}