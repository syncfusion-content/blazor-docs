@using Syncfusion.Blazor.RichTextEditor

<SfRichTextEditor>
    <RichTextEditorToolbarSettings Items="@Items" />
    <RichTextEditorVideoSettings LayoutOption="DisplayLayoutOptions.Break"></RichTextEditorVideoSettings>
    <h5>Rich Text Editor Video Display</h5>
    <p>The Rich Text Editor allows you to insert video files and control their display behavior.</p>
    <ul>
        <li>When set to <b>Break</b>, the video appears as a separate block element.</li>
        <li>When set to <b>Inline</b>, the video appears within the text flow alongside other content.</li>
    </ul>
    <h5>Try It Out!</h5>
    <video controls>
        <source src="https://cdn.syncfusion.com/ej2/richtexteditor-resources/RTE-Ocean-Waves.mp4" type="video/mp4" />
    </video>
</SfRichTextEditor>

@code {
    private List<ToolbarItemModel> Items = new List<ToolbarItemModel>()
    {
        new ToolbarItemModel() { Command = ToolbarCommand.Video }
    };
}