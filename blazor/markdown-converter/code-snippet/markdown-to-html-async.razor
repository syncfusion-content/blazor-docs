@using Syncfusion.Blazor.MarkdownConverter
@using Syncfusion.Blazor.RichTextEditor

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <h3>Markdown Input</h3>
            <SfRichTextEditor @bind-Value="markdownContent" Height="300px" EditorMode="EditorMode.Markdown">
            </SfRichTextEditor>
            <button @onclick="ConvertAsync" class="btn btn-primary mt-2">Convert Asynchronously</button>
        </div>
        <div class="col-md-6">
            <h3>HTML Output</h3>
            <div class="preview-panel border p-3">
                @if (isConverting)
                {
                    <p class="text-info">Converting...</p>
                }
                else if (!string.IsNullOrEmpty(htmlOutput))
                {
                    <div>@((MarkupString)htmlOutput)</div>
                }
                else
                {
                    <p class="text-muted">HTML preview will appear here...</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string markdownContent = @"# Large Document

## Section 1
This is a large document with extensive content.

## Section 2
Multiple paragraphs and sections for demonstration.

## Section 3
More content to demonstrate asynchronous processing.";
    
    private string htmlOutput = "";
    private bool isConverting = false;

    private async Task ConvertAsync()
    {
        isConverting = true;
        var options = new MarkdownConverterOptions { Gfm = true };
        htmlOutput = await SfMarkdownConverter.ToHtmlAsync(markdownContent, options);
        isConverting = false;
    }
}